#Genomic analysis HW 4

#I always start a session by navigating to the class directory and loading the conda environment 
cd /data/Reynolds/GenomicAnalysisCourse
conda activate /data/Reynolds/GenomicAnalysisCourse/conda_envs/course_env/

#I then navigate to my working directory and create a new directory called HW4
cd ../
ls -l
cd ejk0091/
cd data/
ls -l
mkdir HW4
ls -l

#I made my new working directory, but need to move my trimmed files into the new HW4 directory 
cd HW3
ls -l
cp *_trimmed.fastq.gz ../HW4/
cd ../
ls -l
cd HW4
ls -l
#I see the 6 trimmed fasrq.gz files

# I now need to map the trimmed FASTQ files to hg38 with bwa mem
bwa mem -t 4 \
-R "@RG\tID:L002\tSM:L002\tPL:ILLUMINA\tLB:L002\tPU:L002" \
/data/Reynolds/GenomicAnalysisCourse/reference/hg38.fa.gz \
L002_R1_trimmed.fastq.gz \
L002_R2_trimmed.fastq.gz \
> L002.sam
#prior to this code above I kept making spelling errors and messing up the direction of the slants, finally got it working (chat)

#took forever, remembered I could write it as a slurm and submit it

